<%= form_with model: @loyalty_program do |form| %>
  <% if @loyalty_program.errors.any? %>
    <div class="alert alert-danger border-0 rounded-4">
      <%= @loyalty_program.errors.full_messages.join(", ") %>
    </div>
  <% end %>

  <div class="mb-4">
    <%= form.label :name, "Nome do programa", class: "form-label fw-semibold" %>
    <%= form.text_field :name, class: "form-control form-control-lg", placeholder: "Ex: Corte, Barba, Granola 500g, Camiseta" %>
  </div>

  <div class="mb-4">
    <%= form.label :service_id, "Item/Serviço vinculado", class: "form-label fw-semibold" %>
    <%= form.select :service_id,
                    [["Todos os itens/serviços", nil]] + @services.map { |service| [service.name, service.id] },
                    {},
                    class: "form-select form-select-lg" %>

    <div class="form-text">
      Escolha um item específico ou deixe como geral para contar qualquer venda/serviço.
    </div>
  </div>

  <div class="mb-4">
    <%= form.label :required_visits, "Quantidade de pontos para ganhar", class: "form-label fw-semibold" %>
    <%= form.number_field :required_visits, class: "form-control form-control-lg", min: 1 %>
  </div>

  <div class="mb-4">
    <%= form.label :reward_description, "Descrição da recompensa", class: "form-label fw-semibold" %>
    <%= form.text_field :reward_description, class: "form-control form-control-lg", placeholder: "Ex: Corte grátis, Produto grátis, 10% de desconto" %>
  </div>

  <div class="form-check form-switch mb-4">
    <%= form.check_box :active, class: "form-check-input" %>
    <%= form.label :active, "Programa ativo", class: "form-check-label" %>
  </div>

  <div class="d-flex gap-2">
    <%= form.submit "Salvar programa", class: "btn btn-primary btn-lg" %>
    <%= link_to "Cancelar", loyalty_programs_path, class: "btn btn-outline-secondary btn-lg" %>
  </div>
<% end %>