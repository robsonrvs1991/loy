<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <p class="text-muted mb-1">Programa de fidelidade</p>
    <h1 class="h3 mb-0"><%= @loyalty_program.name %></h1>
  </div>

  <div class="d-flex gap-2">
    <%= link_to "Editar", edit_loyalty_program_path(@loyalty_program), class: "btn btn-primary" %>
    <%= link_to "Voltar", loyalty_programs_path, class: "btn btn-outline-secondary" %>
  </div>
</div>

<div class="row g-4">
  <div class="col-lg-8">
    <div class="card loy-card">
      <div class="card-body p-4 p-md-5">
        <div class="row g-3">
          <div class="col-md-6">
            <div class="border rounded-4 p-4 bg-light h-100">
              <p class="text-muted mb-2">Item/Serviço</p>
              <h2 class="h4 mb-0">
                <%= @loyalty_program.service&.name || "Todos os itens/serviços" %>
              </h2>
            </div>
          </div>

          <div class="col-md-6">
            <div class="border rounded-4 p-4 bg-light h-100">
              <p class="text-muted mb-2">Status</p>
              <% if @loyalty_program.active? %>
                <span class="badge text-bg-success fs-6">Ativo</span>
              <% else %>
                <span class="badge text-bg-secondary fs-6">Inativo</span>
              <% end %>
            </div>
          </div>

          <div class="col-md-6">
            <div class="border rounded-4 p-4 bg-light h-100">
              <p class="text-muted mb-2">Meta</p>
              <div class="display-6 fw-bold"><%= @loyalty_program.required_visits %></div>
              <p class="text-muted mb-0">ponto(s)</p>
            </div>
          </div>

          <div class="col-md-6">
            <div class="border rounded-4 p-4 bg-light h-100">
              <p class="text-muted mb-2">Recompensa</p>
              <h2 class="h4 mb-0"><%= @loyalty_program.reward_description %></h2>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="col-lg-4">
    <div class="card loy-card">
      <div class="card-body p-4">
        <h2 class="h5 mb-3">Como este programa funciona</h2>

        <p class="text-muted mb-0">
          Quando o cliente acumular
          <strong><%= @loyalty_program.required_visits %> ponto(s)</strong>
          <% if @loyalty_program.service.present? %>
            no item/serviço <strong><%= @loyalty_program.service.name %></strong>,
          <% else %>
            em qualquer item/serviço,
          <% end %>
          o sistema irá gerar a recompensa:
          <strong><%= @loyalty_program.reward_description %></strong>.
        </p>
      </div>
    </div>
  </div>
</div>