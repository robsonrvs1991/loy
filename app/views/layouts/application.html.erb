<!DOCTYPE html>
<html>
  <head>
    <title>Loy | Fidelidade simples para negócios locais</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" rescue nil %>
    <%= javascript_importmap_tags rescue nil %>

    <style>
      body {
        background: #f6f7fb;
      }

      .loy-navbar {
        background: linear-gradient(135deg, #111827, #1f2937);
      }

      .loy-logo-box {
        background: #ffffff;
        border-radius: 12px;
        padding: 4px 7px;
      }

      .loy-brand-text {
        letter-spacing: -0.03em;
      }

      .loy-nav-link {
        color: rgba(255,255,255,.78) !important;
        font-weight: 500;
      }

      .loy-nav-link:hover {
        color: #ffffff !important;
      }

      .loy-main {
        min-height: calc(100vh - 90px);
      }

      .loy-card {
        border: 0;
        border-radius: 18px;
        box-shadow: 0 10px 30px rgba(15, 23, 42, .08);
      }

      .btn-loy {
        background: #111827;
        border-color: #111827;
        color: #ffffff;
      }

      .btn-loy:hover {
        background: #030712;
        border-color: #030712;
        color: #ffffff;
      }
    </style>
  </head>

  <body>
    <% client_area = request.path.start_with?("/cliente") %>
    <% owner_area = request.path.start_with?("/owner") %>
    <% app_area = request.path.start_with?("/app") %>

    <nav class="navbar navbar-expand-lg navbar-dark loy-navbar shadow-sm mb-4">
      <div class="container">

        <% if owner_area %>
          <%= link_to owner_dashboard_path, class: "navbar-brand d-flex align-items-center fw-bold" do %>
            <span class="loy-logo-box me-2">
              <%= image_tag "logo.png", height: 36 %>
            </span>
            <span class="loy-brand-text">Loy Admin</span>
          <% end %>

          <% if owner? %>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#loyNavbar">
              <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="loyNavbar">
              <div class="navbar-nav ms-auto align-items-lg-center">
                <%= link_to "Dashboard", owner_dashboard_path, class: "nav-link loy-nav-link" %>
                <%= link_to "Empresas", owner_companies_path, class: "nav-link loy-nav-link" %>
                <%= button_to "Sair", logout_path, method: :delete, class: "btn btn-outline-light btn-sm ms-lg-3 mt-2 mt-lg-0" %>
              </div>
            </div>
          <% end %>

        <% elsif client_area %>
          <%= link_to client_logged_in? ? client_portal_path : client_login_path, class: "navbar-brand d-flex align-items-center fw-bold" do %>
            <span class="loy-logo-box me-2">
              <%= image_tag "logo.png", height: 36 %>
            </span>
            <span class="loy-brand-text">Loy</span>
          <% end %>

          <div class="navbar-nav ms-auto align-items-center">
            <span class="navbar-text text-white me-3 d-none d-md-inline">Meu cartão fidelidade</span>

            <% if client_logged_in? %>
              <%= button_to "Sair", client_logout_path, method: :delete, class: "btn btn-outline-light btn-sm" %>
            <% else %>
              <%= link_to "Entrar", client_login_path, class: "btn btn-outline-light btn-sm" %>
            <% end %>
          </div>

        <% elsif app_area || (logged_in? && business?) %>
          <%= link_to app_dashboard_path, class: "navbar-brand d-flex align-items-center fw-bold" do %>
            <span class="loy-logo-box me-2">
              <%= image_tag "logo.png", height: 36 %>
            </span>
            <span class="loy-brand-text">Loy</span>
          <% end %>

          <% if logged_in? && business? %>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#loyNavbar">
              <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="loyNavbar">
              <div class="navbar-nav ms-auto align-items-lg-center">
                <%= link_to "Dashboard", app_dashboard_path, class: "nav-link loy-nav-link" %>
                <%= link_to "Clientes", customers_path, class: "nav-link loy-nav-link" %>
                <%= link_to "Serviços", services_path, class: "nav-link loy-nav-link" %>
                <%= link_to "Atendimentos", appointments_path, class: "nav-link loy-nav-link" %>
                <%= link_to "Recompensas", rewards_path, class: "nav-link loy-nav-link" %>
                <%= link_to "Fidelidade", loyalty_programs_path, class: "nav-link loy-nav-link" %>
                <%= button_to "Sair", logout_path, method: :delete, class: "btn btn-outline-light btn-sm ms-lg-3 mt-2 mt-lg-0" %>
              </div>
            </div>
          <% end %>

        <% else %>
          <%= link_to root_path, class: "navbar-brand d-flex align-items-center fw-bold" do %>
            <span class="loy-logo-box me-2">
              <%= image_tag "logo.png", height: 36 %>
            </span>
            <span class="loy-brand-text">Loy</span>
          <% end %>

          <div class="navbar-nav ms-auto flex-row align-items-center gap-2">
            <%= link_to "Entrar", login_path, class: "nav-link loy-nav-link" %>
            <%= link_to "Cadastre-se", signup_path, class: "btn btn-light btn-sm fw-semibold px-3" %>
          </div>
        <% end %>

      </div>
    </nav>

    <main class="container loy-main pb-5">
      <% if notice.present? %>
        <div class="alert alert-success border-0 shadow-sm rounded-4"><%= notice %></div>
      <% end %>

      <% if alert.present? %>
        <div class="alert alert-danger border-0 shadow-sm rounded-4"><%= alert %></div>
      <% end %>

      <%= yield %>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>