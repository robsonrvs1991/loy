<div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3 mb-4">
  <div>
    <div class="d-flex align-items-center gap-2 mb-2">
      <span class="badge text-bg-primary rounded-pill px-3 py-2">Catálogo</span>
      <span class="text-muted small">Itens, produtos e serviços do negócio</span>
    </div>

    <h1 class="fw-bold mb-1">Itens/Serviços</h1>
    <p class="text-muted mb-0">
      Cadastre tudo que pode gerar pontos: produtos, serviços, atendimentos ou itens vendidos.
    </p>
  </div>

  <div>
    <%= link_to new_service_path, class: "btn btn-primary btn-lg shadow-sm" do %>
      + Novo item/serviço
    <% end %>
  </div>
</div>

<div class="row g-3 mb-4">
  <div class="col-md-4">
    <div class="card border-0 shadow-sm h-100">
      <div class="card-body">
        <p class="text-muted mb-1">Total cadastrado</p>
        <h3 class="fw-bold mb-0"><%= @services.count %></h3>
      </div>
    </div>
  </div>

  <div class="col-md-4">
    <div class="card border-0 shadow-sm h-100">
      <div class="card-body">
        <p class="text-muted mb-1">Ativos</p>
        <h3 class="fw-bold text-success mb-0"><%= @active_services_count %></h3>
      </div>
    </div>
  </div>

  <div class="col-md-4">
    <div class="card border-0 shadow-sm h-100">
      <div class="card-body">
        <p class="text-muted mb-1">Inativos</p>
        <h3 class="fw-bold text-secondary mb-0"><%= @inactive_services_count %></h3>
      </div>
    </div>
  </div>
</div>

<div class="card border-0 shadow-sm">
  <div class="card-header bg-white border-0 py-3">
    <div class="d-flex justify-content-between align-items-center">
      <div>
        <h5 class="fw-bold mb-0">Catálogo de itens/serviços</h5>
        <small class="text-muted">Controle o que gera pontos nos programas de fidelidade.</small>
      </div>
    </div>
  </div>

  <div class="card-body p-0">
    <% if @services.any? %>
      <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
          <thead class="table-light">
            <tr>
              <th class="ps-4">Nome</th>
              <th>Pontos gerados</th>
              <th>Status</th>
              <th class="text-end pe-4">Ações</th>
            </tr>
          </thead>

          <tbody>
            <% @services.each do |service| %>
              <tr>
                <td class="ps-4">
                  <div class="fw-semibold"><%= service.name %></div>
                  <small class="text-muted">Item/serviço cadastrado no catálogo</small>
                </td>

                <td>
                  <span class="badge rounded-pill text-bg-light border">
                    <%= service.points %> ponto<%= "s" if service.points.to_i != 1 %>
                  </span>
                </td>

                <td>
                  <% if service.active? %>
                    <span class="badge rounded-pill text-bg-success">Ativo</span>
                  <% else %>
                    <span class="badge rounded-pill text-bg-secondary">Inativo</span>
                  <% end %>
                </td>

                <td class="text-end pe-4">
                  <div class="btn-group">
                    <%= link_to "Ver", service_path(service), class: "btn btn-sm btn-outline-secondary" %>
                    <%= link_to "Editar", edit_service_path(service), class: "btn btn-sm btn-outline-primary" %>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <div class="text-center py-5 px-4">
        <div class="display-6 mb-3">🧾</div>
        <h5 class="fw-bold">Nenhum item/serviço cadastrado ainda</h5>
        <p class="text-muted mb-4">
          Comece cadastrando os produtos ou serviços que poderão gerar pontos para os clientes.
        </p>

        <%= link_to "Cadastrar primeiro item/serviço", new_service_path, class: "btn btn-primary" %>
      </div>
    <% end %>
  </div>
</div>