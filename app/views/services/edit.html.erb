<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <span class="badge text-bg-primary rounded-pill px-3 py-2 mb-2">Editar cadastro</span>
    <h1 class="fw-bold mb-1">Editar item/serviço</h1>
    <p class="text-muted mb-0">
      Atualize as informações de <strong><%= @service.name %></strong>.
    </p>
  </div>

  <%= link_to "Voltar", services_path, class: "btn btn-outline-secondary" %>
</div>

<div class="row justify-content-center">
  <div class="col-lg-8">
    <div class="card border-0 shadow-sm">
      <div class="card-body p-4">
        <%= render "form" %>
      </div>
    </div>
  </div>
</div>